        "# Calculate cumulative returns\n",
        "cumulative_returns = (1 + returns).cumprod()\n",
        "\n",
        "# Calculate the difference in cumulative returns\n",
        "differences = cumulative_returns.diff(axis=1)\n",
        "\n",
        "# Plot the difference in cumulative returns\n",
        "plt.figure(figsize=(12, 6))\n",
        "for i in range(1, len(tickers)):\n",
        "    plt.plot(differences.index, differences.iloc[:,i], label=f\"{tickers[i]} vs {tickers[i-1]}\")\n",
        "plt.title('Difference in Cumulative Returns of Two Portfolios')  # Set the title\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Difference in Cumulative Returns')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "\n",
        "# Calculate and print the difference in total returns\n",
        "total_returns = (cumulative_returns.iloc[-1] -1 ) * 100\n",
        "print(\"Total Returns:\")\n",
        "print(total_returns)\n",
        "\n",
        "for i in range(1, len(tickers)):\n",
        "    diff = total_returns[tickers[i]] - total_returns[tickers[i-1]]\n",
        "    print(f\"\\nDifference in total returns of {tickers[i]} and {tickers[i-1]}: {diff:.2f}%\")\n"
