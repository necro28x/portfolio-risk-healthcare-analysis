        "import yfinance as yf\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "from datetime import datetime\n",
        "\n",
        "# Define the tickers\n",
        "tickers = ['UNH', 'CI', '^GSPC']  # UNH, Cigna, and S&P 500\n",
        "\n",
        "# Define the date range\n",
        "incident_date = '2024-12-04'  # Date of the incident\n",
        "start_date = '2024-03-15'  # Start date for historical data\n",
        "end_date = '2025-03-15'    # End date for historical data\n",
        "\n",
        "# Fetch the stock data\n",
        "data = yf.download(tickers, start=start_date, end=end_date)\n",
        "\n",
        "# Calculate daily returns\n",
        "returns = data['Close'].pct_change().dropna()\n",
        "\n",
        "# Split the data into before and after the incident\n",
        "before_incident = returns[:incident_date]\n",
        "after_incident = returns[incident_date:]\n",
        "\n",
        "# Calculate cumulative returns before and after the incident\n",
        "cumulative_returns_before = (1 + before_incident).cumprod()\n",
        "cumulative_returns_after = (1 + after_incident).cumprod()\n",
        "\n",
        "# Plot the cumulative returns for comparison\n",
        "plt.figure(figsize=(12, 6))\n",
        "for ticker in tickers:\n",
        "  plt.plot(cumulative_returns_before[ticker], label=f\"{ticker} Before Incident\")\n",
        "  plt.plot(cumulative_returns_after[ticker], label=f\"{ticker} After Incident\")\n",
        "\n",
        "plt.title('Cumulative Returns Comparison Before and After Incident')\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Cumulative Return')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "\n",
        "# Calculate the total return for each ticker before and after the incident\n",
        "total_return_before = (1 + before_incident).prod() - 1\n",
        "total_return_after = (1 + after_incident).prod() - 1\n",
        "\n",
        "# Print the total returns for each ticker before and after the incident\n",
        "print(\"Total Returns Before Incident:\")\n",
        "for ticker in tickers:\n",
        "  print(f\"{ticker}: {total_return_before[ticker]:.2%}\")\n",
        "\n",
        "print(\"\\nTotal Returns After Incident:\")\n",
        "for ticker in tickers:\n",
        "  print(f\"{ticker}: {total_return_after[ticker]:.2%}\")\n",
        "\n",
        "# Perform comparative analysis\n",
        "for ticker in tickers:\n",
        "  print(f\"\\nComparative Analysis for {ticker}:\")\n",
        "  if total_return_after[ticker] > total_return_before[ticker]:\n",
        "    print(\"The stock outperformed after the incident.\")\n",
