        "# ================================\n",
        "# OLS MARKET MODEL EVENT STUDY\n",
        "# ================================\n",
        "\n",
        "import statsmodels.api as sm\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import yfinance as yf\n",
        "\n",
        "# Define estimation and event windows\n",
        "estimation_start = '2024-03-15'\n",
        "estimation_end = '2024-11-15'\n",
        "\n",
        "event_start = '2024-12-04'\n",
        "event_end = '2025-03-15'\n",
        "\n",
        "# Download adjusted close prices\n",
        "tickers = ['UNH', '^GSPC']\n",
        "\n",
        "data = yf.download(tickers,\n",
        "                   start=estimation_start,\n",
        "                   end=event_end)['Close']\n",
        "\n",
        "# Calculate daily returns\n",
        "returns = data.pct_change().dropna()\n",
        "\n",
        "# Split estimation and event windows\n",
        "estimation_window = returns.loc[estimation_start:estimation_end]\n",
        "event_window = returns.loc[event_start:event_end]\n",
        "\n",
        "# Define dependent and independent variables\n",
        "X_est = estimation_window['^GSPC']\n",
        "Y_est = estimation_window['UNH']\n",
        "\n",
        "# Add constant for alpha estimation\n",
        "X_est = sm.add_constant(X_est)\n",
        "\n",
        "# Run OLS regression\n",
        "model = sm.OLS(Y_est, X_est).fit()\n",
        "\n",
        "# Print regression summary\n",
        "print(model.summary())\n",
        "\n",
        "# -----------------------------\n",
        "# Expected Returns\n",
        "# -----------------------------\n",
        "\n",
        "X_event = sm.add_constant(event_window['^GSPC'])\n",
        "\n",
        "event_window['Expected_Return'] = model.predict(X_event)\n",
        "\n",
        "# -----------------------------\n",
        "# Abnormal Returns\n",
        "# -----------------------------\n",
        "\n",
        "event_window['Abnormal_Return'] = (\n",
        "    event_window['UNH'] -\n",
        "    event_window['Expected_Return']\n",
        ")\n",
        "\n",
        "# -----------------------------\n",
        "# Cumulative Abnormal Return\n",
        "# -----------------------------\n",
        "\n",
        "event_window['CAR'] = (\n",
        "    1 + event_window['Abnormal_Return']\n",
